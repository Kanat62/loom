  "optionalDependencies": {
    "better-sqlite3": "^11.3.0",
    "playwright": "^1.61.1",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "express": "^5.2.1"
  }
