{
  "name": "loom",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "LOOM — автономный инженер разработки (см. docs/LOOM_TZ_v4.md, docs/LOOM_DEV_GUIDE.md)",
  "scripts": {
    "talk": "node --env-file=.env --no-warnings bin/talk.js",
    "cli": "node --env-file=.env --no-warnings bin/cli.js",
    "ingest": "node --env-file=.env --no-warnings bin/ingest.js",
    "resume": "node --env-file=.env --no-warnings bin/resume.js",
    "ask": "node --env-file=.env --no-warnings bin/ask.js",
    "dash": "node --env-file=.env --no-warnings bin/dash.js",
    "telegram": "node --env-file=.env --no-warnings bin/telegram.js",
    "mock": "node --env-file=.env --env-file=.env.mock --no-warnings core/mock.js",
    "race": "node --env-file=.env --env-file=.env.mock --no-warnings evals/race.js",
    "budget-eval": "node --env-file=.env --env-file=.env.mock --no-warnings evals/budget.js",
    "interview-eval": "node --env-file=.env --no-warnings evals/interview.js",
    "interview-eval:mock": "node --env-file=.env --env-file=.env.mock --no-warnings evals/interview.js",
    "bank": "node --env-file=.env --no-warnings evals/bank.js",
    "bank:mock": "node --env-file=.env --env-file=.env.mock --no-warnings evals/bank.js",
    "fts-eval:mock": "node --env-file=.env --env-file=.env.mock --no-warnings evals/fts.js"
