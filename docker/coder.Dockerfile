# Комната кодера (§12 ТЗ v4, Фаза 4 DEV_GUIDE §6). В варианте А сюда уезжает
# ИСПОЛНЕНИЕ (checkRunner + npm install), не вызов модели — модель звонит
# claude-cli с хоста, харнесс пишет файлы на хосте, а вот ЗАПУСК критериев и
# установка зависимостей продукта происходят в этом контейнере.
#
# Зависимости продукта ставятся НА ЭТАПЕ СБОРКИ образа из package.json,
# который координатор кладёт в workspace/ по packages-плану архитектора
# (шрам 22) — соответствует §12.2: "зависимости ставятся на этапе сборки
# образа... нужен пакет посреди задачи → статус «нужен пакет» → пересборка".
# Собирается заново при каждом обновлении packages-плана (см. docker.js).
FROM node:22-slim

WORKDIR /workspace

# Копируются из build context = workspace/ (см. docker.js:buildWorkspaceImage).
# Если package.json ещё нет (свежий проект без пакетов) — сборка не падает.
COPY package.json package-lock.json* ./
RUN if [ -f package.json ]; then npm install --no-audit --no-fund || true; fi

# Сам код продукта монтируется томом при запуске (-v workspace:/workspace),
# не копируется в образ — образ переиспользуется между задачами одного дерева,
# файлы меняются на каждом ходу кодера.
CMD ["bash"]
