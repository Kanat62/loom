# Скопируйте в .env и заполните. .env НИКОГДА не коммитится (§20.7, шрам 33).

# HTTP-провайдер (опционально, ветка шлюза выключена по умолчанию — см. gateway.js)
NIM_API_KEY=

# claude-cli — провайдер по умолчанию, работает через `claude login` (подписка),
# отдельный API-ключ для него не нужен.

# GitHub CLI (Фаза 5) — токен НЕ здесь: `gh` хранит его в своей собственной
# связке (`gh auth login`), .env ничего не получает (шрам 33). Единственный
# флаг — включение публикации, по умолчанию выключено (сдача не требует сети):
# GITHUB_PUSH=1

# Режим детерминированного прогона без вызовов моделей (§24)
# MOCK=1

# Подавляет живой прогресс в терминале (router/advisor/architect/coder/
# tester/coordinator), не трогает итоговые отчёты — для evals
# LOOM_QUIET=1

# Порт дашборда (Фаза 8, §22, node:http на 127.0.0.1, npm run dash) — по
# умолчанию 4173, если не задано
# DASH_PORT=4173

# Telegram-вход (опционально, П§7, не входит в release-критерий) — задайте,
# чтобы включить npm run telegram; без него скрипт просто ничего не делает
# TELEGRAM_BOT_TOKEN=

# Maintenance-минимум (§18, П§7.3) — лимит автономных мёржей в сутки,
# по умолчанию 1000 (гейт есть, но не мешает обычной разработке)
# AUTO_MERGES_PER_DAY=1000
